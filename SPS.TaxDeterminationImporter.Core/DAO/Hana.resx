  <data name="TaxDeterminationUsage_GetToExport" xml:space="preserve">
    <value>SELECT TCD3."Tcd2Id", OUSG."Usage", TCD5."TaxCode", TCD5."ExpTaxCode" "TaxCodeExpense"
FROM TCD1
	INNER JOIN TCD2
		ON TCD2."Tcd1Id" = TCD1."AbsId"
	INNER JOIN TCD3
		ON TCD3."Tcd2Id" = TCD2."AbsId"
	INNER JOIN TCD5
		ON TCD5."Tcd3Id" = TCD3."AbsId"
	INNER JOIN OUSG
		ON OUSG.ID = TCD5."UsageCode"
WHERE TCD1."TcdId" = 1
AND TCD1."Priority" = {0}</value>
  </data>
  <data name="TaxDeterminationValues_GetToExport" xml:space="preserve">
    <value>SELECT
	TCD2."AbsId" "Tcd2Id",
	FN_TAXCODE_EXPORT(TCD1."KeyFld_1", TCD2."KeyFld_1_V") "Value1",
	FN_TAXCODE_EXPORT(TCD1."KeyFld_2", TCD2."KeyFld_2_V") "Value2",
	FN_TAXCODE_EXPORT(TCD1."KeyFld_3", TCD2."KeyFld_3_V") "Value3",
	FN_TAXCODE_EXPORT(TCD1."KeyFld_4", TCD2."KeyFld_4_V") "Value4",
	FN_TAXCODE_EXPORT(TCD1."KeyFld_5", TCD2."KeyFld_5_V") "Value5",
	TCD3."EfctFrom" "DateFrom",
	TCD3."EfctTo"	"DateTo"
FROM TCD1
	INNER JOIN TCD2
		ON TCD2."Tcd1Id" = TCD1."AbsId"
	INNER JOIN TCD3
		ON TCD3."Tcd2Id" = TCD2."AbsId"
WHERE TCD1."TcdId" = 1
AND TCD1."Priority" = {0}</value>
  </data>
  <data name="TaxDetermination_GetByPriority" xml:space="preserve">
    <value>SELECT "AbsId" FROM TCD1 WHERE "Priority" = {0}</value>
  </data>
  <data name="TaxDetermination_GetDisplayOrder" xml:space="preserve">
    <value>SELECT "DispOrder" FROM TCD2
WHERE "Tcd1Id" = {0}
AND "KeyFld_1_V" = '{1}'
AND IFNULL("KeyFld_2_V", '') = '{2}'
AND IFNULL("KeyFld_3_V", '') = '{3}'
AND IFNULL("KeyFld_4_V", '') = '{4}'
AND IFNULL("KeyFld_5_V", '') = '{5}'</value>
  </data>
  <data name="TaxDetermination_GetFields" xml:space="preserve">
    <value>SELECT
	'Y'	"#",
	FN_GET_KEYFIELDDESCRIPTION(TCD1."KeyFld_1", TCD2."KeyFld_1_V") "{1}",
	FN_GET_KEYFIELDDESCRIPTION(TCD1."KeyFld_2", TCD2."KeyFld_2_V") "{2}",
	FN_GET_KEYFIELDDESCRIPTION(TCD1."KeyFld_3", TCD2."KeyFld_3_V") "{3}",
	FN_GET_KEYFIELDDESCRIPTION(TCD1."KeyFld_4", TCD2."KeyFld_4_V") "{4}",
	FN_GET_KEYFIELDDESCRIPTION(TCD1."KeyFld_5", TCD2."KeyFld_5_V") "{5}"
FROM TCD1
	INNER JOIN TCD2
		ON TCD2."Tcd1Id" = TCD1."AbsId"
WHERE TCD1."TcdId" = 1
AND TCD1."Priority" = {0}
ORDER BY TCD2."DispOrder"</value>
  </data>
  <data name="TaxDetermination_GetKeyValues" xml:space="preserve">
    <value>SELECT
	"DispOrder" "DisplayOrder",
	"KeyFld_1_V" "Value1",
	IFNULL("KeyFld_2_V", '') "Value2",
	IFNULL("KeyFld_3_V", '') "Value3",
	IFNULL("KeyFld_4_V", '') "Value4",
	IFNULL("KeyFld_5_V", '') "Value5"
FROM TCD2
WHERE "Tcd1Id" = {0}</value>
  </data>
  <data name="TaxDetermination_GetMaxDisplayOrder" xml:space="preserve">
    <value>SELECT MAX("DispOrder") FROM TCD2 WHERE "Tcd1Id" = {0}</value>
  </data>
