  <data name="UDF_GetValidValues" xml:space="preserve">
    <value>SELECT UFD1."FldValue" 
FROM CUFD
    INNER JOIN UFD1 
        ON CUFD."TableID" = UFD1."TableID"
        AND CUFD."FieldID" = UFD1."FieldID"
 WHERE CUFD."TableID" = '{0}'
 AND CUFD."AliasID" = '{1}'</value>
  </data>
  <data name="Usage_GetIdByDescription" xml:space="preserve">
    <value>SELECT ID FROM OUSG WHERE LOWER("Usage") = '{0}' OR LOWER("Descr") = '{0}'</value>
